{
  "name": "popkit",
  "version": "1.0.0",
  "description": "AI-powered development workflows for Claude Code",
  "private": true,
  "workspaces": [
    "packages/popkit-core",
    "packages/popkit-dev",
    "packages/popkit-ops",
    "packages/popkit-research",
    "packages/shared-py",
    "packages/docs"
  ],
  "scripts": {
    "plugin:test": "echo 'Run /popkit:plugin test in Claude Code'",
    "docs:dev": "npm run dev --workspace=packages/docs",
    "docs:build": "npm run build --workspace=packages/docs",
    "docs:preview": "npm run preview --workspace=packages/docs",
    "lint:py": "cd packages/shared-py && ruff check .",
    "lint:ts": "eslint packages/**/*.ts --max-warnings 0",
    "lint:json": "prettier --check \"**/*.json\" --ignore-path .prettierignore",
    "lint:md": "prettier --check \"**/*.md\" --ignore-path .prettierignore",
    "lint": "npm run lint:py && npm run lint:ts",
    "format:py": "cd packages/shared-py && ruff format .",
    "format:ts": "prettier --write \"packages/**/*.ts\"",
    "format:json": "prettier --write \"**/*.json\" --ignore-path .prettierignore",
    "format:md": "prettier --write \"**/*.md\" --ignore-path .prettierignore",
    "format": "npm run format:py && npm run format:ts && npm run format:json && npm run format:md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jrc1883/popkit-claude.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "plugin",
    "ai",
    "development",
    "workflow"
  ],
  "author": "Joseph Cannon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jrc1883/popkit-claude/issues"
  },
  "homepage": "https://github.com/jrc1883/popkit-claude#readme",
  "engines": {
    "node": ">=20.3.0",
    "npm": ">=9.6.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "h3": "^1.15.5"
  }
}

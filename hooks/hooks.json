{
  "$schema": "https://claude.ai/schemas/hooks.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/pre-tool-use.py"],
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/agent-orchestrator.py"],
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/chain-validator.py"],
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/post-tool-use.py"],
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/agent-observability.py"],
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python",
            "args": ["power-mode/checkin-hook.py"],
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/context-monitor.py"],
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/quality-gate.py"],
            "timeout": 180000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/agent-context-integration.py"],
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/chain-metrics.py"],
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/user-prompt-submit.py"],
            "timeout": 3000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/session-start.py"],
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/knowledge-sync.py"],
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/stop.py"],
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/subagent-stop.py"],
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/output-validator.py"],
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["hooks/notification.py"],
            "timeout": 3000
          }
        ]
      }
    ]
  }
}

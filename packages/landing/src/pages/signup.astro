---
import AuthLayout from '../layouts/AuthLayout.astro';

const plan = Astro.url.searchParams.get('plan') || 'free';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://popkit-cloud-api.joseph-cannon.workers.dev';
---

<AuthLayout title="Sign Up">
  <div class="card">
    <h1 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-2">
      Create your account
    </h1>
    <p class="text-center text-gray-600 dark:text-gray-400 mb-6">
      {plan === 'pro' ? 'Start your 14-day Pro trial' : 'Get started for free'}
    </p>

    <form id="signup-form" class="space-y-4">
      <input type="hidden" name="plan" value={plan} />

      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
          Email address
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="input"
          placeholder="you@example.com"
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
          Password
        </label>
        <input
          type="password"
          id="password"
          name="password"
          required
          minlength="8"
          class="input"
          placeholder="At least 8 characters"
        />
      </div>

      <div id="error-message" class="hidden text-red-500 text-sm"></div>

      <button type="submit" class="btn-primary w-full">
        {plan === 'pro' ? 'Start Pro Trial' : 'Create Account'}
      </button>
    </form>

    <div class="relative my-6">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-gray-200 dark:border-slate-700"></div>
      </div>
      <div class="relative flex justify-center text-sm">
        <span class="px-2 bg-white dark:bg-slate-800 text-gray-500">or</span>
      </div>
    </div>

    <a
      href={`${apiUrl}/v1/auth/github`}
      class="btn-secondary w-full flex items-center justify-center gap-2"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      Continue with GitHub
    </a>

    <p class="mt-6 text-center text-sm text-gray-600 dark:text-gray-400">
      Already have an account? <a href="/login" class="text-popkit-purple hover:underline font-medium">Log in</a>
    </p>
  </div>
</AuthLayout>

<script define:vars={{ apiUrl }}>
  document.getElementById('signup-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const errorEl = document.getElementById('error-message');
    const submitBtn = form.querySelector('button[type="submit"]');

    // Reset error
    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating account...';

    try {
      const response = await fetch(`${apiUrl}/v1/auth/signup`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: form.email.value,
          password: form.password.value,
          plan: form.plan.value,
        }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Signup failed');
      }

      // Store token temporarily for dashboard
      sessionStorage.setItem('popkit_temp_token', data.token);

      // Redirect to success/checkout based on plan
      if (form.plan.value === 'pro') {
        // Redirect to Stripe checkout
        window.location.href = data.checkout_url || '/success';
      } else {
        // Redirect to success page with API key
        window.location.href = '/success';
      }
    } catch (error) {
      errorEl.textContent = error.message;
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = form.plan.value === 'pro' ? 'Start Pro Trial' : 'Create Account';
    }
  });
</script>

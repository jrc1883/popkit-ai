---
import BaseLayout from '../layouts/BaseLayout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://popkit-cloud-api.joseph-cannon.workers.dev';
---

<BaseLayout title="Welcome to PopKit">
  <section class="py-24">
    <div class="max-w-2xl mx-auto px-4">
      <div class="card text-center">
        <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Welcome to PopKit!
        </h1>

        <p class="text-gray-600 dark:text-gray-400 mb-8">
          Your account is ready. Here's your API key to unlock premium features in Claude Code.
        </p>

        <div class="bg-gray-50 dark:bg-slate-700 rounded-lg p-4 mb-6">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Your API Key
          </label>
          <div class="flex items-center gap-2">
            <input
              type="text"
              id="api-key"
              readonly
              class="input font-mono text-sm bg-white dark:bg-slate-800"
              value="Loading..."
            />
            <button
              id="copy-btn"
              class="btn-secondary px-4 py-3 flex-shrink-0"
              title="Copy to clipboard"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </button>
          </div>
          <p id="copy-status" class="text-sm text-green-500 mt-2 hidden">Copied!</p>
        </div>

        <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 mb-8 text-left">
          <h3 class="font-semibold text-blue-900 dark:text-blue-200 mb-2">Next Steps:</h3>
          <ol class="list-decimal list-inside space-y-2 text-sm text-blue-800 dark:text-blue-300">
            <li>Copy your API key above</li>
            <li>Set it in your terminal:
              <code class="bg-blue-100 dark:bg-blue-900/40 px-2 py-0.5 rounded text-xs">export POPKIT_API_KEY=your_key_here</code>
            </li>
            <li>Run <code class="bg-blue-100 dark:bg-blue-900/40 px-2 py-0.5 rounded text-xs">/popkit:account status</code> to verify</li>
          </ol>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/dashboard" class="btn-primary">
            Go to Dashboard
          </a>
          <a href="https://github.com/jrc1883/popkit-plugin#installation" class="btn-secondary">
            Installation Guide
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ apiUrl }}>
  async function loadApiKey() {
    const apiKeyInput = document.getElementById('api-key');

    // Check for temp token from signup
    const token = sessionStorage.getItem('popkit_temp_token') || localStorage.getItem('popkit_token');

    if (!token) {
      apiKeyInput.value = 'Please log in to view your API key';
      return;
    }

    try {
      const response = await fetch(`${apiUrl}/v1/account/keys`, {
        headers: { 'Authorization': `Bearer ${token}` },
      });

      if (!response.ok) throw new Error('Failed to load API key');

      const data = await response.json();
      const primaryKey = data.keys?.find(k => k.name === 'Default Key') || data.keys?.[0];

      if (primaryKey) {
        apiKeyInput.value = primaryKey.key;
        // Move temp token to permanent storage
        localStorage.setItem('popkit_token', token);
        sessionStorage.removeItem('popkit_temp_token');
      } else {
        apiKeyInput.value = 'No API key found';
      }
    } catch (error) {
      apiKeyInput.value = 'Error loading API key';
      console.error(error);
    }
  }

  // Copy to clipboard
  document.getElementById('copy-btn').addEventListener('click', async () => {
    const apiKey = document.getElementById('api-key').value;
    const copyStatus = document.getElementById('copy-status');

    try {
      await navigator.clipboard.writeText(apiKey);
      copyStatus.classList.remove('hidden');
      setTimeout(() => copyStatus.classList.add('hidden'), 2000);
    } catch (err) {
      alert('Failed to copy. Please select and copy manually.');
    }
  });

  loadApiKey();
</script>

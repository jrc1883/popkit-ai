---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';

const features = [
  {
    title: 'Power Mode',
    description: 'Multi-agent orchestration for complex tasks. File-based for free, hosted Redis for Pro.',
    icon: '🚀',
  },
  {
    title: 'Smart Workflows',
    description: '7-phase feature development with automated code review, testing, and documentation.',
    icon: '⚡',
  },
  {
    title: 'Collective Learning',
    description: 'Share and discover patterns from the community. Learn from solved problems.',
    icon: '🧠',
  },
  {
    title: 'Session Persistence',
    description: 'Pick up where you left off. Context restored across sessions automatically.',
    icon: '💾',
  },
  {
    title: 'Premium Agents',
    description: '30+ specialized agents for security, performance, testing, and more.',
    icon: '🤖',
  },
  {
    title: 'Custom Generation',
    description: 'Generate project-specific MCP servers, skills, and routines.',
    icon: '🎨',
  },
];
---

<BaseLayout title="AI-Powered Development Workflows">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50 dark:from-slate-900 dark:via-slate-900 dark:to-slate-800"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="text-center">
        <h1 class="text-4xl md:text-6xl font-bold mb-6">
          <span class="gradient-text">Supercharge</span> Claude Code<br />
          with Intelligent Workflows
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto mb-8">
          PopKit orchestrates Claude Code's full power with smart agents, multi-agent coordination,
          and project-aware tooling. Build faster, debug smarter, ship confidently.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/signup" class="btn-primary text-lg">
            Start Free Trial
          </a>
          <a href="https://github.com/jrc1883/popkit-plugin" class="btn-secondary text-lg">
            View on GitHub
          </a>
        </div>
        <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
          14-day free trial. No credit card required.
        </p>
      </div>

      <!-- Terminal Demo -->
      <div class="mt-16 max-w-4xl mx-auto">
        <div class="card bg-slate-900 dark:bg-slate-950 p-0 overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-3 bg-slate-800 dark:bg-slate-900 border-b border-slate-700">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="ml-2 text-sm text-gray-400">claude code</span>
          </div>
          <pre class="p-6 text-sm font-mono text-gray-300 overflow-x-auto"><code><span class="text-green-400">$</span> /popkit:dev full "Add user authentication"

<span class="text-purple-400">Phase 1: Discovery</span> - Understanding requirements...
<span class="text-purple-400">Phase 2: Exploration</span> - Analyzing codebase...
<span class="text-purple-400">Phase 3: Architecture</span> - Designing solution...
<span class="text-purple-400">Phase 4: Implementation</span> - Writing code...
<span class="text-purple-400">Phase 5: Review</span> - Checking quality (80+ confidence)...

<span class="text-green-400">✓</span> Authentication system implemented
<span class="text-green-400">✓</span> 15 tests passing
<span class="text-green-400">✓</span> Security audit complete
<span class="text-green-400">✓</span> Documentation updated</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-24 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Everything you need to <span class="gradient-text">build faster</span>
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          PopKit enhances Claude Code with intelligent orchestration, specialized agents, and powerful workflows.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="card group hover:shadow-xl transition-shadow">
            <div class="text-4xl mb-4">{feature.icon}</div>
            <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-white">{feature.title}</h3>
            <p class="text-gray-600 dark:text-gray-400">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="py-24 bg-gray-50 dark:bg-slate-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Simple, transparent <span class="gradient-text">pricing</span>
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Start free, upgrade when you need more power. All plans include the core plugin.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <PricingCard
          name="Free"
          price="$0"
          period=""
          description="For individual developers"
          features={[
            'File-based Power Mode (2-3 agents)',
            '30+ specialized agents',
            'Session capture & restore',
            'Community patterns (limited)',
            'Core workflows & skills',
          ]}
          cta="Get Started"
          ctaLink="/signup"
        />

        <PricingCard
          name="Pro"
          price="$9"
          description="For professional developers"
          features={[
            'Hosted Redis Power Mode (6+ agents)',
            'Persistent sessions (7 days)',
            'Unlimited community patterns',
            'Custom MCP server generation',
            'Priority bug detection',
            'Email support',
          ]}
          cta="Start Free Trial"
          ctaLink="/signup?plan=pro"
          highlighted={true}
          badge="Most Popular"
        />

        <PricingCard
          name="Team"
          price="$29"
          period="/seat/mo"
          description="For development teams"
          features={[
            'Everything in Pro',
            'Multi-user sessions',
            'Private team patterns',
            'Team analytics dashboard',
            'Session history (90 days)',
            'Priority support',
          ]}
          cta="Contact Sales"
          ctaLink="mailto:team@popkit.dev"
        />
      </div>

      <p class="text-center mt-8 text-gray-500 dark:text-gray-400">
        All plans include a 14-day free trial of Pro features. <a href="/pricing" class="text-popkit-purple hover:underline">Compare all features</a>
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-gradient-to-r from-popkit-purple to-popkit-blue">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to supercharge your development?
      </h2>
      <p class="text-xl text-purple-100 mb-8">
        Join developers using PopKit to build faster and smarter with Claude Code.
      </p>
      <a href="/signup" class="inline-block px-8 py-4 bg-white text-popkit-purple font-bold rounded-lg hover:bg-gray-100 transition-colors text-lg">
        Start Your Free Trial
      </a>
    </div>
  </section>
</BaseLayout>

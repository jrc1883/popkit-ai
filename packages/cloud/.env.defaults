# ==============================================================================
# PopKit Cloud - Default Environment Variables
# ==============================================================================
#
# FILE: apps/popkit/packages/cloud/.env.defaults
# PURPOSE: Non-sensitive default configuration (committed to git)
# OVERRIDE: Create .dev.vars for local development secrets
#
# LOADING ORDER (Cloudflare Workers):
#   1. .dev.vars               (local dev secrets - gitignored, highest priority)
#   2. wrangler.toml [vars]    (app defaults - committed)
#   3. wrangler secrets        (production secrets - encrypted)
#
# NOTE: Most configuration is in wrangler.toml [vars] section
# This file is here for consistency with monorepo environment management
#
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Metadata
# ------------------------------------------------------------------------------

# Application Name
APP_NAME=PopKit Cloud API

# Application Version (synced with package.json)
APP_VERSION=0.2.5

# ------------------------------------------------------------------------------
# Environment Configuration
# ------------------------------------------------------------------------------

# Environment Type (overridden by wrangler.toml and deployment context)
# Values: development | staging | production
# Default: development (wrangler.toml sets production)
ENVIRONMENT=development

# ------------------------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------------------------

# Enable semantic agent search (requires Upstash Vector)
# Default: true (disable if Upstash Vector not configured)
FEATURE_SEMANTIC_SEARCH=true

# Enable Power Mode coordination (requires Upstash Redis)
# Default: true (disable if Upstash Redis not configured)
FEATURE_POWER_MODE=true

# Enable durable workflows (requires QStash)
# Default: false (optional feature)
FEATURE_WORKFLOWS=false

# ------------------------------------------------------------------------------
# Logging & Debugging
# ------------------------------------------------------------------------------

# Log Level (error | warn | info | debug)
# Default: info (production should use warn or error)
LOG_LEVEL=info

# Enable debug mode (verbose logging)
# Default: false
DEBUG=false

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------

# Allowed origins for CORS (comma-separated)
# Default: * (allow all - should be restricted in production)
CORS_ALLOWED_ORIGINS=*

# ------------------------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------------------------

# API Version
API_VERSION=v1

# API Base Path
API_BASE_PATH=/api

# ------------------------------------------------------------------------------
# Notes
# ------------------------------------------------------------------------------
#
# Most PopKit Cloud configuration is in wrangler.toml because Cloudflare Workers
# use a different environment variable pattern than traditional Node.js apps.
#
# For secrets (API keys, tokens), use .dev.vars (local) or wrangler secret (production).
# See .dev.vars.template for required secret variables.
#
# ==============================================================================

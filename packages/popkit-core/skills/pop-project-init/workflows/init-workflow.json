{
  "name": "Project Initialization Workflow",
  "version": "2.0.0",
  "description": "Interactive guided workflow for initializing new projects with best practices (Issue #65)",
  "phases": [
    {
      "id": "detect",
      "name": "Detect Environment",
      "description": "Run interactive detection and gather user preferences",
      "steps": [
        {
          "id": "interactive_detect",
          "name": "Run Interactive Detection",
          "type": "automated",
          "script": "scripts/interactive_init.py",
          "description": "Detects monorepo, stack, quality tools, and premium features"
        },
        {
          "id": "monorepo_config",
          "name": "Monorepo Configuration",
          "type": "ask_user_question",
          "conditional": "detection.monorepo.is_monorepo == true",
          "question": "Monorepo detected. How should PopKit be configured?",
          "header": "Workspace",
          "options": [
            {
              "label": "App-specific config (Recommended)",
              "value": "app_specific",
              "description": "Configure PopKit for this app only with its own .claude/popkit/"
            },
            {
              "label": "Shared workspace config",
              "value": "shared",
              "description": "Single PopKit config at workspace root shared by all apps"
            },
            {
              "label": "Both (hybrid)",
              "value": "hybrid",
              "description": "Workspace config with app-specific overrides"
            }
          ]
        },
        {
          "id": "stack_selection",
          "name": "Stack Selection",
          "type": "ask_user_question",
          "question": "What type of project would you like to initialize?",
          "header": "Stack",
          "options_source": "detection.stack.suggestions",
          "max_options": 4,
          "description": "Auto-populated from detection results. Detected stack shown first."
        },
        {
          "id": "detect_language",
          "name": "Detect Primary Language",
          "prompt": "What is the primary language?",
          "type": "selection",
          "conditional": "stack_selection in ['cli', 'library']",
          "options": [
            { "label": "TypeScript", "value": "typescript" },
            { "label": "Python", "value": "python" },
            { "label": "Go", "value": "go" },
            { "label": "Rust", "value": "rust" }
          ]
        }
      ]
    },
    {
      "id": "configure",
      "name": "Configure Project",
      "description": "Create structure and configure quality gates",
      "steps": [
        {
          "id": "create_structure",
          "name": "Create Directory Structure",
          "type": "automated",
          "action": "create_directories"
        },
        {
          "id": "generate_config",
          "name": "Generate Configuration Files",
          "type": "automated",
          "files": [
            "package.json or pyproject.toml",
            "tsconfig.json (if TypeScript)",
            ".eslintrc.js (if ESLint)",
            ".gitignore",
            "README.md"
          ]
        },
        {
          "id": "quality_gates",
          "name": "Quality Gate Selection",
          "type": "ask_user_question",
          "question": "What quality gate level?",
          "header": "Quality",
          "options": [
            {
              "label": "Basic",
              "value": "basic",
              "description": "Formatting only (Prettier/Ruff). Fast, minimal overhead."
            },
            {
              "label": "Standard (Recommended)",
              "value": "standard",
              "description": "Formatting + linting + type checking. Good balance."
            },
            {
              "label": "Strict",
              "value": "strict",
              "description": "All of Standard + pre-commit hooks + test requirements."
            },
            {
              "label": "Enterprise",
              "value": "enterprise",
              "description": "All of Strict + security scanning + audit logging."
            }
          ]
        },
        {
          "id": "popkit_config",
          "name": "Create PopKit Config",
          "type": "automated",
          "action": "generate_popkit_config",
          "description": "Generates .claude/popkit/config.json with stack and quality selections"
        },
        {
          "id": "update_claude_md",
          "name": "Update CLAUDE.md",
          "type": "automated",
          "action": "surgical_claude_md_update"
        }
      ]
    },
    {
      "id": "features",
      "name": "Feature Setup",
      "description": "Configure Power Mode and premium features",
      "steps": [
        {
          "id": "power_mode",
          "name": "Power Mode Setup",
          "type": "ask_user_question",
          "question": "Set up Power Mode for multi-agent orchestration?",
          "header": "Power Mode",
          "options": [
            {
              "label": "Native Async (Recommended)",
              "value": "native",
              "description": "5+ agents, zero setup (requires Claude Code 2.0.64+)"
            },
            {
              "label": "Upstash Redis",
              "value": "redis",
              "description": "10+ agents, cloud-based, env vars only"
            },
            {
              "label": "File Mode (Fallback)",
              "value": "file",
              "description": "2-3 agents, automatic fallback"
            },
            {
              "label": "Skip for now",
              "value": "skip",
              "description": "Can be configured later with /popkit:power init"
            }
          ]
        },
        {
          "id": "premium_features",
          "name": "Premium Features",
          "type": "ask_user_question",
          "conditional": "detection.premium.is_authenticated == true || detection.premium.has_voyage_key == true",
          "question": "Which premium features would you like to enable?",
          "header": "Features",
          "multiSelect": true,
          "options": [
            {
              "label": "Power Mode (Recommended)",
              "value": "power_mode",
              "description": "Multi-agent orchestration for parallel task execution"
            },
            {
              "label": "Semantic Search",
              "value": "semantic_search",
              "description": "Natural language search for skills, agents, and commands"
            },
            {
              "label": "Cloud Sync",
              "value": "cloud_sync",
              "description": "Cross-session state and analytics via PopKit Cloud"
            }
          ]
        }
      ]
    },
    {
      "id": "finalize",
      "name": "Finalize Setup",
      "description": "Complete project setup with git and next actions",
      "steps": [
        {
          "id": "update_gitignore",
          "name": "Update .gitignore",
          "type": "automated",
          "action": "update_gitignore"
        },
        {
          "id": "git_setup",
          "name": "Git Setup",
          "type": "automated",
          "conditional": "git_init == true",
          "commands": ["git init", "git add .", "git commit -m 'Initial commit'"]
        },
        {
          "id": "next_action",
          "name": "Next Action",
          "type": "ask_user_question",
          "question": "What would you like to do next?",
          "header": "Next",
          "options": [
            {
              "label": "Analyze codebase (Recommended)",
              "value": "analyze",
              "description": "Run /popkit:project analyze for deep codebase insights"
            },
            {
              "label": "Setup quality gates",
              "value": "setup",
              "description": "Configure pre-commit hooks with /popkit:project setup"
            },
            {
              "label": "View issues",
              "value": "issues",
              "description": "Check GitHub issues with /popkit:issue list"
            },
            {
              "label": "Done for now",
              "value": "done",
              "description": "End initialization - run /popkit:routine morning later"
            }
          ]
        }
      ]
    }
  ],
  "templates": {
    "nextjs": "templates/nextjs/",
    "fastapi": "templates/fastapi/",
    "cli": "templates/cli/",
    "library": "templates/library/",
    "plugin": "templates/plugin/",
    "cloudflare-workers": "templates/cloudflare-workers/",
    "react-spa": "templates/react-spa/"
  }
}

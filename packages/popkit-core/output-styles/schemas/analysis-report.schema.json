{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Analysis Report Schema",
  "description": "Schema for general analysis reports from researcher agent",
  "type": "object",
  "required": ["projectName", "summary"],
  "properties": {
    "projectName": {
      "type": "string",
      "description": "Name of project being analyzed"
    },
    "status": {
      "type": "string",
      "description": "Analysis status"
    },
    "date": {
      "type": "string",
      "description": "Date of analysis"
    },
    "summary": {
      "type": "string",
      "description": "Summary of analysis findings"
    },
    "recommendation": {
      "type": "string",
      "description": "Analysis recommendations"
    },
    "scope": {
      "type": "string",
      "description": "Scope of analysis"
    }
  }
}

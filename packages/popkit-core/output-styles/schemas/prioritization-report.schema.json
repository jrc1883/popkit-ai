{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prioritization Report Schema",
  "description": "Schema for feature prioritization reports from feature-prioritizer agent",
  "type": "object",
  "required": ["summary"],
  "properties": {
    "projectName": {
      "type": "string",
      "description": "Name of project being prioritized"
    },
    "status": {
      "type": "string",
      "description": "Prioritization status"
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Confidence in prioritization (0-100)"
    },
    "summary": {
      "type": "string",
      "description": "Summary of prioritization analysis"
    },
    "recommendation": {
      "type": "string",
      "description": "Prioritization recommendations"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "API Design Report Schema",
  "description": "Schema for API design reports from api-designer agent",
  "type": "object",
  "required": ["summary"],
  "properties": {
    "projectName": {
      "type": "string",
      "description": "Name of project/API being designed"
    },
    "status": {
      "type": "string",
      "description": "API design status"
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Confidence in API design (0-100)"
    },
    "summary": {
      "type": "string",
      "description": "Summary of API design"
    },
    "recommendation": {
      "type": "string",
      "description": "API design recommendations"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Migration Report Schema",
  "description": "Schema for migration analysis reports from migration-specialist agent",
  "type": "object",
  "required": ["summary"],
  "properties": {
    "projectName": {
      "type": "string",
      "description": "Name of project being migrated"
    },
    "status": {
      "type": "string",
      "description": "Migration status"
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Confidence in migration plan (0-100)"
    },
    "summary": {
      "type": "string",
      "description": "Summary of migration analysis and plan"
    },
    "recommendation": {
      "type": "string",
      "description": "Migration recommendations"
    }
  }
}

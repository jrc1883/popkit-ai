{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Specification Schema",
  "description": "Schema for agent specification documents from meta-agent",
  "type": "object",
  "required": ["summary"],
  "properties": {
    "status": {
      "type": "string",
      "description": "Agent specification status"
    },
    "summary": {
      "type": "string",
      "description": "Summary of agent specification"
    },
    "recommendation": {
      "type": "string",
      "description": "Recommendations for agent implementation"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rollback Report Schema",
  "description": "Schema for rollback reports from rollback-specialist agent",
  "type": "object",
  "required": ["summary"],
  "properties": {
    "status": {
      "type": "string",
      "description": "Rollback status"
    },
    "healthScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "System health score after rollback (0-100)"
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "Severity of issue requiring rollback"
    },
    "summary": {
      "type": "string",
      "description": "Summary of rollback actions and results"
    },
    "recommendation": {
      "type": "string",
      "description": "Post-rollback recommendations"
    }
  }
}

{
  "test_id": "plugin-structure-integrity",
  "category": "structure",
  "name": "Plugin Structure Integrity",
  "description": "Verify plugin directory structure and required files are present and valid",
  "severity": "critical",
  "test_cases": [
    {
      "case_id": "required-files-exist",
      "name": "Required plugin files exist",
      "assertions": [
        {
          "type": "file_exists",
          "path": ".claude-plugin/plugin.json",
          "description": "Plugin manifest must exist"
        },
        {
          "type": "file_exists",
          "path": "hooks/hooks.json",
          "description": "Hooks configuration must exist"
        },
        {
          "type": "file_exists",
          "path": "agents/config.json",
          "description": "Agent configuration must exist"
        },
        {
          "type": "file_exists",
          "path": "README.md",
          "description": "README must exist"
        }
      ]
    },
    {
      "case_id": "plugin-json-valid",
      "name": "plugin.json is valid and complete",
      "file": ".claude-plugin/plugin.json",
      "assertions": [
        {
          "type": "json_valid",
          "field": "file",
          "description": "Must be valid JSON"
        },
        {
          "type": "has_field",
          "field": "name",
          "description": "Must have name field"
        },
        {
          "type": "has_field",
          "field": "version",
          "description": "Must have version field"
        },
        {
          "type": "has_field",
          "field": "description",
          "description": "Must have description field"
        },
        {
          "type": "regex",
          "field": "version",
          "pattern": "^\\d+\\.\\d+\\.\\d+",
          "description": "Version must follow semver"
        }
      ]
    },
    {
      "case_id": "hooks-json-valid",
      "name": "hooks.json is valid and follows schema",
      "file": "hooks/hooks.json",
      "assertions": [
        {
          "type": "json_valid",
          "field": "file"
        },
        {
          "type": "has_field",
          "field": "hooks",
          "description": "Must have hooks object"
        },
        {
          "type": "schema_valid",
          "schema": "https://claude.ai/schemas/hooks.json",
          "description": "Must follow official hooks schema"
        }
      ]
    },
    {
      "case_id": "agent-config-valid",
      "name": "agents/config.json is valid",
      "file": "agents/config.json",
      "assertions": [
        {
          "type": "json_valid",
          "field": "file"
        },
        {
          "type": "has_field",
          "field": "agents",
          "description": "Must have agents configuration"
        },
        {
          "type": "has_field",
          "field": "routing",
          "description": "Must have routing configuration"
        }
      ]
    },
    {
      "case_id": "directory-structure",
      "name": "Standard directory structure exists",
      "assertions": [
        {
          "type": "directory_exists",
          "path": "skills",
          "description": "Skills directory should exist"
        },
        {
          "type": "directory_exists",
          "path": "commands",
          "description": "Commands directory should exist"
        },
        {
          "type": "directory_exists",
          "path": "agents",
          "description": "Agents directory should exist"
        },
        {
          "type": "directory_exists",
          "path": "hooks",
          "description": "Hooks directory should exist"
        }
      ]
    },
    {
      "case_id": "no-orphaned-files",
      "name": "No orphaned or unused files",
      "scan_pattern": "**/*.py",
      "assertions": [
        {
          "type": "file_referenced",
          "description": "All .py files should be referenced in hooks.json or used by skills"
        }
      ]
    },
    {
      "case_id": "agent-files-registered",
      "name": "All agent definitions are registered in config.json",
      "scan_pattern": "agents/**/*.md",
      "assertions": [
        {
          "type": "agent_registered",
          "config_file": "agents/config.json",
          "description": "All agent .md files should be registered in config.json"
        }
      ]
    }
  ],
  "dependencies": [
    "popkit_shared.utils.plugin_validator",
    "popkit_shared.utils.json_schema_validator"
  ],
  "notes": [
    "Plugin structure must follow Claude Code plugin conventions",
    "All configuration files must be valid JSON",
    "Agent and skill files must be properly registered",
    "No orphaned or unused files should exist"
  ]
}

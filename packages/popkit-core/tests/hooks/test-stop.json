{
  "test_id": "hook-stop-protocol",
  "category": "hooks",
  "name": "Stop Hook Verifier Dispatcher",
  "description": "Verify stop.py implements the Phase 1a-ii verifier dispatcher: archives the pending claim ledger written by /checkpoint into a per-turn bundle, writes a status='missing' stub when no checkpoint exists, and never logs raw stdin (privacy).",
  "severity": "critical",
  "hook_file": "hooks/stop.py",
  "test_cases": [
    {
      "case_id": "basic-session-stop",
      "name": "Basic session termination produces a missing-stub bundle",
      "input": {
        "event": "Stop",
        "session_id": "test-session-123",
        "duration": 3600,
        "reason": "user_exit"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0,
          "description": "Stop hook must never block Claude Code on exit"
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "status"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "success"
        },
        {
          "type": "has_field",
          "field": "ledger_status"
        },
        {
          "type": "duration",
          "max_ms": 5000,
          "description": "Must stay under hooks.json Stop budget"
        }
      ]
    },
    {
      "case_id": "no-checkpoint-emits-stub-warning",
      "name": "Missing /checkpoint produces ledger_status='missing'",
      "input": {
        "event": "Stop",
        "session_id": "test-session-no-ckpt",
        "duration": 1800
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "ledger_status"
        }
      ]
    },
    {
      "case_id": "transcript-not-saved-privacy",
      "name": "Transcript is NOT persisted (privacy regression guard)",
      "input": {
        "event": "Stop",
        "session_id": "test-session-789",
        "save_chat": true,
        "transcript": [
          { "role": "user", "content": "Hello" },
          { "role": "assistant", "content": "Hi there" }
        ]
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        }
      ]
    },
    {
      "case_id": "invalid-json-input",
      "name": "Handles invalid JSON input gracefully (treats as empty payload)",
      "input": "invalid json{{{",
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0,
          "description": "Stop hook must never block Claude Code"
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "success"
        }
      ]
    },
    {
      "case_id": "empty-input",
      "name": "Handles empty input gracefully",
      "input": {},
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "success"
        }
      ]
    },
    {
      "case_id": "timestamp-added",
      "name": "Adds ISO timestamp to response",
      "input": {
        "event": "Stop",
        "session_id": "test-session-time"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "timestamp"
        }
      ]
    }
  ],
  "dependencies": ["hooks/stop.py"],
  "notes": [
    "Phase 1a-ii dispatcher contract: read pending claim ledger written by /checkpoint, archive into <repo>/.claude/popkit/verifier-bundles/<session_id>/<turn_id>/ledger.json, or write a status='missing' stub if no /checkpoint was called.",
    "The previous logs/stop.json raw-input dump was a privacy violation flagged by Codex and is removed.",
    "The previous logs/chat.json transcript save is also removed (same privacy rationale).",
    "Stop hook must NEVER exit non-zero — Claude Code's Stop pipeline cannot be blocked by hook bugs.",
    "Bundle directory writes are atomic via .tmp + Path.replace.",
    "Pending ledger is deleted only after a successful archive."
  ]
}

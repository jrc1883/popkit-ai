{
  "test_id": "hook-output-validator-protocol",
  "category": "hooks",
  "name": "Output-Validator Hook Schema Validation",
  "description": "Verify output-validator.py validates agent outputs against declared output_style schemas",
  "severity": "critical",
  "hook_file": "hooks/output-validator.py",
  "test_cases": [
    {
      "case_id": "valid-debugging-report",
      "name": "Valid debugging report with all required fields",
      "input": {
        "event": "SubagentStop",
        "agent": "bug-whisperer",
        "output_style": "debugging-report",
        "output": "## Debugging Report: Authentication Bug\n\n**Severity:** high\n\n### Symptom\nUsers unable to log in.\n\n### Summary\nFixed authentication token validation."
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "valid"
        },
        {
          "type": "has_field",
          "field": "confidence"
        },
        {
          "type": "contains",
          "field": "valid",
          "expected": true
        }
      ]
    },
    {
      "case_id": "invalid-missing-required-fields",
      "name": "Invalid output missing required fields",
      "input": {
        "event": "SubagentStop",
        "agent": "security-auditor",
        "output_style": "security-audit-report",
        "output": "## Security Audit Report: MyApp\n\n### Summary\nNo critical vulnerabilities found."
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0,
          "description": "Should not block even on invalid output"
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "invalid"
        },
        {
          "type": "has_field",
          "field": "missing_fields"
        },
        {
          "type": "has_field",
          "field": "suggestion"
        },
        {
          "type": "contains",
          "field": "valid",
          "expected": false
        }
      ]
    },
    {
      "case_id": "skip-no-output-style",
      "name": "Skips validation when no output_style declared",
      "input": {
        "event": "SubagentStop",
        "agent": "code-explorer",
        "output": "Explored the codebase successfully."
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "skip"
        },
        {
          "type": "contains",
          "field": "reason",
          "expected": "no output_style declared"
        }
      ]
    },
    {
      "case_id": "warning-schema-not-found",
      "name": "Warning when schema file not found",
      "input": {
        "event": "SubagentStop",
        "agent": "custom-agent",
        "output_style": "nonexistent-schema",
        "output": "Some output"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "warning"
        },
        {
          "type": "contains",
          "field": "reason",
          "expected": "schema not found"
        }
      ]
    },
    {
      "case_id": "extract-handoff-fields",
      "name": "Extracts handoff pattern fields",
      "input": {
        "event": "SubagentStop",
        "agent": "code-reviewer",
        "output_style": "handoff-pattern",
        "output": "**From:** code-reviewer\n**To:** test-writer-fixer\n**Task:** Write tests for auth module\n**Handoff Confidence:** 85"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "extracted_fields"
        },
        {
          "type": "has_field",
          "field": "confidence"
        }
      ]
    },
    {
      "case_id": "extract-health-score",
      "name": "Extracts numeric health scores",
      "input": {
        "event": "SubagentStop",
        "agent": "deployment-validator",
        "output_style": "deployment-health",
        "output": "## Deployment Health Report\n\n**Health Score:** 92\n**Status:** healthy\n**Date:** 2025-12-28"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "extracted_fields"
        }
      ]
    },
    {
      "case_id": "confidence-calculation",
      "name": "Calculates confidence score based on field completeness",
      "input": {
        "event": "SubagentStop",
        "agent": "performance-optimizer",
        "output_style": "performance-report",
        "output": "## Performance Report\n\n**Status:** optimized\n**Summary:** Reduced load time by 40%"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "confidence"
        },
        {
          "type": "has_field",
          "field": "field_count"
        }
      ]
    },
    {
      "case_id": "empty-output",
      "name": "Handles empty output gracefully",
      "input": {
        "event": "SubagentStop",
        "agent": "rapid-prototyper",
        "output_style": "prototype-demo",
        "output": ""
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0,
          "description": "Should not fail on empty output"
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "invalid"
        },
        {
          "type": "has_field",
          "field": "missing_fields"
        }
      ]
    },
    {
      "case_id": "invalid-json-input",
      "name": "Handles invalid JSON input gracefully",
      "input": "invalid json{{{",
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0,
          "description": "Should not block on JSON errors"
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "error"
        },
        {
          "type": "contains",
          "field": "error",
          "expected": "Invalid JSON input"
        }
      ]
    },
    {
      "case_id": "extract-summary-section",
      "name": "Extracts summary section from markdown",
      "input": {
        "event": "SubagentStop",
        "agent": "accessibility-guardian",
        "output_style": "accessibility-audit",
        "output": "## Accessibility Audit Report\n\n### Summary\nIdentified 5 WCAG violations.\n\n**Severity:** medium"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "extracted_fields"
        }
      ]
    },
    {
      "case_id": "suggestion-for-invalid",
      "name": "Provides helpful suggestion for invalid output",
      "input": {
        "event": "SubagentStop",
        "agent": "migration-specialist",
        "output_style": "migration-plan",
        "output": "Started migration."
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "status",
          "expected": "invalid"
        },
        {
          "type": "has_field",
          "field": "suggestion"
        },
        {
          "type": "contains",
          "field": "suggestion",
          "expected": "missing required fields"
        }
      ]
    },
    {
      "case_id": "timestamp-added",
      "name": "Adds timestamp to validation result",
      "input": {
        "event": "SubagentStop",
        "agent": "api-designer",
        "output_style": "api-design-doc",
        "output": "## API Design Document\n\n**Status:** draft"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "timestamp"
        }
      ]
    },
    {
      "case_id": "infer-agent-name",
      "name": "Infers agent name from subagent_type if not provided",
      "input": {
        "event": "SubagentStop",
        "subagent_type": "refactoring-expert",
        "output_style": "refactoring-plan",
        "output": "## Refactoring Plan\n\n**Scope:** auth module"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "agent"
        },
        {
          "type": "contains",
          "field": "agent",
          "expected": "refactoring-expert"
        }
      ]
    }
  ],
  "dependencies": [
    "hooks/output-validator.py",
    "output-styles/schemas/*.schema.json",
    "hooks/subagent-stop.py"
  ],
  "notes": [
    "This hook is critical for ensuring agents produce valid, structured output",
    "Validates outputs against JSON schemas defined in output-styles/schemas/",
    "Extracts structured fields from markdown using regex patterns",
    "Calculates confidence score based on required field completeness",
    "Skips validation if no output_style declared (graceful degradation)",
    "Warns if schema file not found but doesn't fail",
    "Provides helpful suggestions when validation fails",
    "Used by subagent-stop.py to detect validation failures and trigger retries",
    "Must not block Claude exit even on errors",
    "Supports multiple output formats: debugging-report, security-audit-report, handoff-pattern, etc."
  ]
}

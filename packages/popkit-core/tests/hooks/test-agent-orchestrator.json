{
  "test_id": "hook-agent-orchestrator-protocol",
  "category": "hooks",
  "name": "Agent Orchestrator Hook Multi-Agent Coordination",
  "description": "Verify agent-orchestrator.py intelligently selects and coordinates agents for Power Mode",
  "severity": "critical",
  "hook_file": "hooks/agent-orchestrator.py",
  "test_cases": [
    {
      "case_id": "intent-build",
      "name": "Build intent selects appropriate agents",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "create a new React component for user profiles",
        "context": {
          "project_type": "web"
        }
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "intent"
        },
        {
          "type": "contains",
          "field": "intent",
          "expected": "build"
        },
        {
          "type": "has_field",
          "field": "suggested_agents"
        }
      ]
    },
    {
      "case_id": "intent-fix",
      "name": "Fix intent selects debugging agents",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "fix the authentication bug causing 401 errors"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "intent",
          "expected": "fix"
        },
        {
          "type": "has_field",
          "field": "suggested_agents"
        }
      ]
    },
    {
      "case_id": "complexity-simple",
      "name": "Simple tasks get lightweight agent selection",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "add a console.log statement"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "complexity",
          "expected": "simple"
        }
      ]
    },
    {
      "case_id": "complexity-complex",
      "name": "Complex tasks get comprehensive agent selection",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "refactor the entire authentication system to use JWT tokens, update all API endpoints, write comprehensive tests, and update documentation"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "contains",
          "field": "complexity",
          "expected": "complex"
        }
      ]
    },
    {
      "case_id": "parallel-execution",
      "name": "Independent agents can run in parallel",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "audit security and optimize performance"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "parallel_groups"
        }
      ]
    },
    {
      "case_id": "sequential-execution",
      "name": "Dependent agents run sequentially",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "write tests and then review the code"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "sequential"
        }
      ]
    },
    {
      "case_id": "keyword-matching",
      "name": "Keyword patterns match agents correctly",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "deploy to production and validate",
        "patterns": {
          "operations": {
            "deployment-validator": ["deploy", "production", "validate"],
            "rollback-specialist": ["rollback", "revert"]
          }
        }
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "suggested_agents"
        }
      ]
    },
    {
      "case_id": "confidence-high",
      "name": "High keyword match produces high confidence",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "review security audit test deployment validate performance"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "confidence"
        }
      ]
    },
    {
      "case_id": "no-agents-matched",
      "name": "Fallback to intent-based selection when no keywords match",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "help me with this thing"
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0,
          "description": "Should provide fallback suggestion"
        },
        {
          "type": "json_valid",
          "field": "stdout"
        },
        {
          "type": "has_field",
          "field": "suggested_agents"
        }
      ]
    },
    {
      "case_id": "telemetry-routing-decision",
      "name": "Emits routing decision telemetry in test mode",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "fix authentication bug",
        "env": {
          "TEST_MODE": "true"
        }
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        }
      ]
    },
    {
      "case_id": "agent-invocation-tracking",
      "name": "Tracks agent invocations for metrics",
      "input": {
        "event": "AgentOrchestration",
        "prompt": "review code and run tests",
        "env": {
          "TEST_MODE": "true"
        }
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0
        },
        {
          "type": "json_valid",
          "field": "stdout"
        }
      ]
    },
    {
      "case_id": "empty-prompt",
      "name": "Handles empty prompt gracefully",
      "input": {
        "event": "AgentOrchestration",
        "prompt": ""
      },
      "assertions": [
        {
          "type": "exit_code",
          "expected": 0,
          "description": "Should handle empty input gracefully"
        },
        {
          "type": "json_valid",
          "field": "stdout"
        }
      ]
    }
  ],
  "dependencies": [
    "hooks/agent-orchestrator.py",
    "hooks/utils/test_telemetry.py",
    ".claude/agents/",
    ".claude/config/keyword-patterns.json",
    ".claude/OPTIMUS_MEMORY_DB.json",
    ".claude/OPTIMUS_CONTEXT.db"
  ],
  "notes": [
    "This hook is critical for Power Mode multi-agent coordination",
    "Analyzes prompts to detect intent, complexity, and domains",
    "Matches keywords to agent capabilities",
    "Plans parallel vs sequential execution based on dependencies",
    "Emits telemetry for behavioral validation (Issue #258)",
    "Falls back to intent-based selection when no keywords match",
    "Confidence score based on keyword match count"
  ]
}

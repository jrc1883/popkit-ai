{
  "name": "@elshaddai/semantic-search",
  "version": "0.1.0",
  "description": "Semantic search package using OpenAI embeddings and pgvector",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "ioredis": "^5.3.0",
    "openai": "^4.69.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "peerDependencies": {
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "keywords": [
    "semantic-search",
    "embeddings",
    "openai",
    "pgvector",
    "vector-search",
    "hybrid-search"
  ],
  "author": "Joseph Cannon <joseph@thehouseofdeals.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jrc1883/elshaddai.git",
    "directory": "packages/semantic-search"
  }
}

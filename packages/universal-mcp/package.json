{
  "name": "@popkit/mcp",
  "version": "1.0.0-beta.1",
  "description": "Universal MCP Server for PopKit - works with Cursor, Continue, Claude Code, and any MCP client",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "popkit-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:sse": "SSE_MODE=true node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "popkit",
    "cursor",
    "continue",
    "claude-code",
    "ai-tools"
  ],
  "author": "Joseph Cannon <joseph@thehouseofdeals.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jrc1883/popkit-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

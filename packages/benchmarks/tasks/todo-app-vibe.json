{
  "id": "todo-app-vibe",
  "name": "Todo App (Vibe-Coded Prompt)",
  "description": "Build a todo app with minimal prompt context. Tests PopKit's ability to clarify requirements and make good default decisions.",
  "category": "standard",
  "language": "javascript",
  "version": "1.0.0",
  "promptQuality": "vibe-coded",

  "initialFiles": {
    "index.html": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Todo App</title>\n</head>\n<body>\n  <h1>Todo App</h1>\n  <div id=\"app\"></div>\n  <script src=\"todo.js\"></script>\n</body>\n</html>",
    "todo.js": "// TODO: Build todo app\n"
  },
  "dependencies": [],
  "setupCommands": [],

  "prompt": "make a todo app. it should let you add and remove todos and save them.",

  "context": "This is intentionally vague to test how well the system handles ambiguous requirements. Vanilla Claude will likely ask clarifying questions. PopKit should use brainstorming to fill gaps and make reasonable assumptions.",
  "maxTokens": 50000,
  "timeoutSeconds": 300,

  "tests": [
    {
      "id": "file-exists",
      "name": "todo.js exists and has content",
      "type": "unit",
      "command": "test -s todo.js && echo 'PASS' || echo 'FAIL'",
      "successPattern": "PASS"
    },
    {
      "id": "has-storage",
      "name": "Has some form of persistence",
      "type": "unit",
      "command": "grep -qE '(localStorage|sessionStorage|indexedDB)' todo.js && echo 'PASS' || echo 'FAIL'",
      "successPattern": "PASS"
    },
    {
      "id": "has-add",
      "name": "Can add todos",
      "type": "unit",
      "command": "grep -qE '(add|push|append|create)' todo.js && echo 'PASS' || echo 'FAIL'",
      "successPattern": "PASS"
    },
    {
      "id": "has-remove",
      "name": "Can remove todos",
      "type": "unit",
      "command": "grep -qE '(remove|delete|filter|splice)' todo.js && echo 'PASS' || echo 'FAIL'",
      "successPattern": "PASS"
    }
  ],

  "qualityChecks": [
    {
      "id": "no-errors",
      "name": "No syntax errors",
      "type": "custom",
      "command": "node --check todo.js 2>&1 || true",
      "weight": 1.0
    }
  ],

  "baseline": {
    "vanilla": {
      "tokenEstimate": 12000,
      "toolCallEstimate": 20,
      "successRate": 0.40,
      "timeEstimate": 180,
      "qualityEstimate": 5.0,
      "notes": "Will likely ask many clarifying questions or make minimal implementation"
    },
    "popkit": {
      "tokenEstimate": 15000,
      "toolCallEstimate": 25,
      "successRate": 0.75,
      "timeEstimate": 200,
      "qualityEstimate": 7.0,
      "notes": "Should use brainstorming to fill gaps, make reasonable assumptions, build something complete"
    }
  },

  "comparisonTo": "todo-app",
  "comparisonNotes": "Same task as todo-app.json but with vibe-coded prompt (minimal context). Tests ability to handle ambiguity and make good default decisions.",

  "tags": ["vibe-coded", "ambiguous", "crud", "dom-manipulation", "beginner-friendly"],
  "author": "PopKit Benchmark Team",
  "createdAt": "2025-12-15T00:00:00Z"
}

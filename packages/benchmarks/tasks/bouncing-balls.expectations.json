{
  "taskId": "bouncing-balls",
  "description": "UI task: Create canvas animation with physics-based bouncing balls",
  "mode": "popkit",

  "agents": {
    "shouldInvoke": [
      {
        "agents": ["ui-designer", "rapid-prototyper"],
        "reason": "UI task should trigger design/prototype agents",
        "required": false,
        "invocationCount": {
          "min": 1
        }
      }
    ],
    "shouldNotInvoke": [
      {
        "agents": ["api-designer", "query-optimizer", "security-auditor", "migration-specialist"],
        "reason": "Backend/infrastructure agents irrelevant for frontend UI task",
        "required": true
      }
    ]
  },

  "skills": {
    "shouldInvoke": [
      {
        "skills": ["document-skills:frontend-design"],
        "reason": "Frontend task should use frontend design skill",
        "required": false
      }
    ],
    "shouldNotInvoke": [
      {
        "skills": ["document-skills:backend-api", "document-skills:database"],
        "reason": "No backend/database work needed",
        "required": true
      }
    ]
  },

  "tools": {
    "expectedPatterns": [
      {
        "pattern": "Write",
        "reason": "Should write balls.js implementation",
        "severity": "critical",
        "minOccurrences": 1
      },
      {
        "pattern": "Read",
        "reason": "Should read index.html to understand canvas setup",
        "severity": "major",
        "minOccurrences": 1
      }
    ],
    "forbiddenPatterns": [
      {
        "pattern": "Bash:npm install",
        "reason": "Vanilla JavaScript task - no dependencies allowed",
        "severity": "major"
      },
      {
        "pattern": "Bash:git clone",
        "reason": "Should not clone external repos",
        "severity": "critical"
      }
    ],
    "sequences": {
      "antiPatterns": [
        {
          "sequence": ["Write", "Write", "Write"],
          "reason": "Multiple consecutive writes suggest inefficient file editing",
          "severity": "minor"
        }
      ]
    }
  },

  "routing": {
    "expectedTriggers": [
      {
        "type": "intent-analysis",
        "value": "build",
        "minimumConfidence": 30
      }
    ],
    "agentSelection": {
      "shouldConsider": ["ui-designer", "rapid-prototyper", "frontend-design"],
      "shouldNotConsider": ["query-optimizer", "migration-specialist", "security-auditor"]
    }
  },

  "performance": {
    "maxToolCalls": 25,
    "maxAgentInvocations": 3,
    "maxTotalDurationMs": 180000
  },

  "decisions": {
    "minimumDecisions": 0,
    "maximumDecisions": 3
  },

  "metadata": {

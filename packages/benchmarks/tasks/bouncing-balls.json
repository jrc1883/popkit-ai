  "dependencies": [],
  "setupCommands": [],

  "prompt": "Create a web page with a canvas showing 5 balls bouncing with realistic physics. Requirements:\n1. Each ball should have a random color and size (10-30px radius)\n2. Balls should start at random positions with random velocities\n3. Balls should bounce off the walls (canvas edges) with proper reflection\n4. Balls should collide with each other (basic collision detection)\n5. Use requestAnimationFrame for smooth animation\n6. Add gravity (balls should fall and bounce)",

  "context": "This is a vanilla JavaScript task. No frameworks or build tools required.",
  "maxTokens": 50000,
  "timeoutSeconds": 300,

  "tests": [
    {
      "id": "file-exists",
      "name": "balls.js file exists and has content",
      "type": "unit",
      "command": "node -e \"const fs=require('fs'); const s=fs.statSync('balls.js'); console.log(s.size > 100 ? 'PASS' : 'FAIL')\"",
      "expectedExitCode": 0,
      "successPattern": "PASS"
    },
    {
      "id": "canvas-element",
      "name": "Canvas element is accessed",
      "type": "unit",
      "command": "node -e \"const fs=require('fs'); const c=fs.readFileSync('balls.js','utf8'); console.log(/getElementById.*canvas|canvas.*getElementById/.test(c) ? 'PASS' : 'FAIL')\"",
      "successPattern": "PASS"
    },
    {
      "id": "animation-loop",
      "name": "Uses requestAnimationFrame",
      "type": "unit",
      "command": "node -e \"const fs=require('fs'); const c=fs.readFileSync('balls.js','utf8'); console.log(/requestAnimationFrame/.test(c) ? 'PASS' : 'FAIL')\"",
      "successPattern": "PASS"
    },
    {
      "id": "ball-count",
      "name": "Creates 5 balls",
      "type": "unit",
      "command": "node -e \"const fs=require('fs'); const c=fs.readFileSync('balls.js','utf8'); console.log(/5|five/i.test(c) ? 'PASS' : 'FAIL')\"",
      "successPattern": "PASS"
    },
    {
      "id": "collision-detection",
      "name": "Implements collision detection",
      "type": "unit",
      "command": "node -e \"const fs=require('fs'); const c=fs.readFileSync('balls.js','utf8'); console.log(/collision|distance|sqrt|Math\\.sqrt/.test(c) ? 'PASS' : 'FAIL')\"",
      "successPattern": "PASS"
    }
  ],


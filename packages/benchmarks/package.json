{
  "name": "@popkit/benchmarks",
  "version": "0.1.0",
  "description": "PopKit benchmarking framework for measuring value proposition",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsx run-benchmark.ts",
    "benchmark:validate": "tsx run-benchmark.ts --validate",
    "validate:all": "tsx validate-all-tasks.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "uuid": "^11.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  }
}

# PopKit Environment Configuration
# Copy this file to .env and fill in your values
# .env files are gitignored and never committed

# =============================================================================
# VOYAGE AI (Embeddings)
# =============================================================================
# Get your API key from: https://dash.voyageai.com/
# Used for semantic search in agent routing and knowledge lookup
VOYAGE_API_KEY=your-voyage-api-key-here

# =============================================================================
# OPTIONAL: Redis (Power Mode)
# =============================================================================
# Only needed if using Redis-based Power Mode (vs file-based fallback)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# =============================================================================
# OPTIONAL: GitHub (Issue Integration)
# =============================================================================
# Usually inherited from gh CLI authentication
# GITHUB_TOKEN=your-github-token

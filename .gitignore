# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.py[cod]

# Node
node_modules/
npm-debug.log
# Keep root package-lock.json but ignore nested ones
packages/*/package-lock.json

# IDE
.idea/
.vscode/
.obsidian/
.cursor/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
nul

# Test artifacts (temporary test directories, not docs/test-results)
/Test[0-9]*/
/test[0-9]*/

# Build outputs
dist/
build/
*.egg-info/

# Cloudflare Workers
.wrangler/
.dev.vars

# Development-only content (not distributed with plugin)
# Uses .local suffix pattern like Claude Code's settings.local.json
packages/*/commands.local/
packages/*/skills.local/
packages/*/agents.local/
packages/*/hooks.local/

# Project-specific generated content
# Output from /popkit:generate-* commands
.generated/

# Power Mode state files (generated during multi-agent orchestration)
packages/popkit-core/power-mode/.claude/

# Local Claude Code project state (created when using PopKit on this repo)
.claude/

# Runtime logs
logs/

# Playwright MCP state
.playwright-mcp/

# Python coverage
.coverage
.coverage.*

# Temporary build artifacts
packages/*/build-*.txt
.popkit/

# Personal session/state files
STATUS.json
.workspace/

# Environment variables (secrets)
.env

# Claude Code temporary files
tmpclaude-*-cwd

# Development/testing scripts (should be in scripts/ or tests/)
cleanup-*.ps1
cleanup-*.sh
fix-*.py
fix-*.sh
test-*.py
create-*.sh
*_body.md
commit_message.txt
issue-audit-report.md

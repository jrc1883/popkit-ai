# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.py[cod]

# Node
node_modules/
npm-debug.log
# Keep root package-lock.json but ignore nested ones
packages/*/package-lock.json

# IDE
.idea/
.vscode/
.obsidian/
.cursor/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
nul

# Test artifacts (temporary test directories, not docs/test-results)
/Test[0-9]*/
/test[0-9]*/

# Build outputs
dist/
build/
*.egg-info/

# Cloudflare Workers
.wrangler/
.dev.vars

# Development-only content (not distributed with plugin)
# Uses .local suffix pattern like Claude Code's settings.local.json
packages/plugin/commands.local/
packages/plugin/skills.local/
packages/plugin/agents.local/
packages/plugin/hooks.local/

# Project-specific generated content
# Output from /popkit:generate-* commands
.generated/

# Power Mode state files (generated during multi-agent orchestration)
packages/plugin/power-mode/.claude/

# Local Claude Code project state (created when using PopKit on this repo)
.claude/

# Runtime logs
logs/

# Playwright MCP state
.playwright-mcp/

# Python coverage
.coverage
.coverage.*

# Sandbox test artifacts and results
packages/benchmarks/results/
packages/benchmarks/analysis/
packages/benchmarks/tasks/real-world/
packages/benchmarks/tasks/standard/
packages/benchmarks/hello.txt
packages/benchmarks/streamtest.txt
packages/benchmarks/pnpm-lock.yaml

# Temporary build artifacts
packages/*/build-*.txt
.popkit/

# Personal session/state files
STATUS.json
.workspace/

# Environment variables (secrets)
.env

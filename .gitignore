# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.py[cod]

# Node (for MCP server template)
node_modules/
npm-debug.log

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test artifacts (temporary test directories, not docs/test-results)
/Test[0-9]*/
/test[0-9]*/

# Build outputs
dist/
build/
*.egg-info/

# Development-only content (not distributed with plugin)
# Uses .local suffix pattern like Claude Code's settings.local.json
commands.local/
skills.local/
agents.local/
hooks.local/

# Project-specific generated content
# Output from /popkit:generate-* commands
.generated/

# Power Mode state files (generated during multi-agent orchestration)
power-mode/.claude/

# Local Claude Code project state (created when using PopKit on this repo)
.claude/

# Environment files (contain API keys)
.env
.env.local
*.env

